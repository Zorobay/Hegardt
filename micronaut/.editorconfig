root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{groovy,java}]
indent_style = space
indent_size = 4
max_line_length = 120
ij_groovy_imports_layout = *,|,java.**,|,javax.**
ij_java_class_count_to_use_import_on_demand = 999
ij_java_names_count_to_use_import_on_demand = 999
ij_groovy_class_count_to_use_import_on_demand = 999
ij_groovy_names_count_to_use_import_on_demand = 999

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{json,ts,js}]
indent_style = space
indent_size = 2

[*.sql]
indent_style = space
indent_size = 4

[*.gradle]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false